{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Optimization": {
        "DispatchMode": "RabbitMq"
    },
    "Cosmos": {
        "DatabaseName": "planner",
        "OptimizationRunsContainerName": "optimizationRuns"
    },
    "ServiceBus": {
        "OptimizationQueueName": "optimization-jobs"
    },
    "Cors": {
        "AllowedOrigins": [
            "https://localhost:7014",
            "http://localhost:5212"
        ]
    },
    "SignalR": {
        "HubName": "planner"
    }
}
