# Environment Variables for Docker Compose

# Google Gemini API Key for AI Analysis
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Credentials Path
# Download your Firebase service account JSON from Firebase Console
# and set the path here (relative to docker-compose.yml or absolute)
FIREBASE_CONFIG_JSON=ey...

# Firestore project id used by Planner.API when publishing pending_analysis/route_insights.
# Example: abundantlife-215910
FIRESTORE_PROJECT_ID=your_firebase_project_id_here
