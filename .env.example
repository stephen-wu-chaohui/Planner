# Environment Variables for Docker Compose

# Google API key used by Planner.API and Planner.AI in docker-compose
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Gemini API key used by Planner.AI in docker-compose
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model used by Planner.AI
GEMINI_MODEL=gemini-2.5-flash

# Firebase Credentials Path
# Download your Firebase service account JSON from Firebase Console
# and set the path here (relative to docker-compose.yml or absolute)
FIREBASE_CONFIG_JSON=ey...

# Firestore project id used by Planner.API when publishing pending_analysis/route_insights.
# Example: abundantlife-215910
FIRESTORE_PROJECT_ID=your_firebase_project_id_here

# Optional Firestore database id. Leave blank for the default database.
# Example: planner
FIRESTORE_DATABASE_ID=

# Async optimization path. Default stays RabbitMq; set AzureServiceBus to test the new path.
OPTIMIZATION_DISPATCH_MODE=RabbitMq

# Local Azure emulator settings for docker compose --profile azure-emulators.
# For native apps talking to the Service Bus emulator, use localhost. Containers in this compose file use servicebus-emulator.
SERVICEBUS_CONNECTION_STRING=Endpoint=sb://localhost;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SAS_KEY_VALUE;UseDevelopmentEmulator=true;
COSMOS_EMULATOR_KEY=cGxhbm5lci1sb2NhbC1jb3Ntb3MtZW11bGF0b3ItZGV2ZWxvcG1lbnQta2V5LTAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMA==
COSMOS_CONNECTION_STRING=AccountEndpoint=https://localhost:8081/;AccountKey=cGxhbm5lci1sb2NhbC1jb3Ntb3MtZW11bGF0b3ItZGV2ZWxvcG1lbnQta2V5LTAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMA==;DisableServerCertificateValidation=True;
COSMOS_DISABLE_SERVER_CERTIFICATE_VALIDATION=true

# Required only for Production API hosting with Azure SignalR.
# Local Development uses the native Planner.API SignalR hub.
AZURE_SIGNALR_CONNECTION_STRING=
